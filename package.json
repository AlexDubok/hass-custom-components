{
  "name": "hass-custom-components",
  "version": "0.0.1",
  "description": "Home assistant custom components",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "node-forge": "^1.3.2",
    "handlebars": "^4.7.9",
    "rollup": "^4.59.0",
    "flatted": "^3.4.2",
    "cacache/tar": "^7.5.4",
    "node-gyp/tar": "^7.5.4"
  },
  "author": "Oleksii Dubok",
  "license": "MIT",
  "scripts": {
    "test": "yarn workspaces foreach --all run test",
    "test:coverage": "yarn workspaces foreach --all run test:coverage",
    "build": "yarn workspaces foreach --all run build",
    "type-check": "yarn workspaces foreach --all run type-check",
    "lint": "yarn workspaces foreach --all run lint"
  },
  "packageManager": "yarn@4.9.1"
}
